{
  "family": "gto-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/gto-ecs-task-execution-role",
  "taskRoleArn":      "arn:aws:iam::ACCOUNT_ID:role/gto-ecs-task-execution-role",
  "containerDefinitions": [
    {
      "name": "gto-app",
      "image": "ACCOUNT_ID.dkr.ecr.ap-northeast-1.amazonaws.com/gto-app:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
          "name": "FIREBASE_SERVICE_ACCOUNT_JSON",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gto/production:FIREBASE_SERVICE_ACCOUNT_JSON::"
        },
        {
          "name": "FIREBASE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gto/production:FIREBASE_API_KEY::"
        },
        {
          "name": "FIREBASE_AUTH_DOMAIN",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gto/production:FIREBASE_AUTH_DOMAIN::"
        },
        {
          "name": "FIREBASE_PROJECT_ID",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gto/production:FIREBASE_PROJECT_ID::"
        },
        {
          "name": "ADMIN_UID",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gto/production:ADMIN_UID::"
        },
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gto/production:GEMINI_API_KEY::"
        },
        {
          "name": "GROQ_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gto/production:GROQ_API_KEY::"
        },
        {
          "name": "PORT",
          "valueFrom": "arn:aws:secretsmanager:ap-northeast-1:ACCOUNT_ID:secret:gto/production:PORT::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/gto-app",
          "awslogs-region":        "ap-northeast-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group":  "true"
        }
      },
      "healthCheck": {
        "command":     ["CMD-SHELL", "curl -f http://localhost:5000/health || exit 1"],
        "interval":    30,
        "timeout":     5,
        "retries":     3,
        "startPeriod": 60
      }
    }
  ]
}
